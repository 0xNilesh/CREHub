# ─── On-chain (Phase 3) — leave empty to use in-memory demo listings ──────────
WORKFLOW_REGISTRY_ADDRESS=
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ─── x402 Gateway (Phase 2) ───────────────────────────────────────────────────
GATEWAY_URL=http://localhost:8080

# ─── Semantic search ──────────────────────────────────────────────────────────
# How often to re-sync workflow listings from chain (ms). Default: 60000 (1 min)
REFRESH_INTERVAL_MS=60000

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
