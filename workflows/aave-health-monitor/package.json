{
  "name": "@crehub/workflow-aave-health-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CREHub Aave health factor monitor — liquidation prevention via Chainlink Price Feeds and x402 agent payments.",
  "scripts": {
    "cre-compile": "bun scripts/cre-compile.ts",
    "simulate": "PATH=$HOME/.cre/bin:$PATH cre workflow simulate . --target local-simulation --http-payload @http_trigger_payload.json --non-interactive --trigger-index 0",
    "simulate:staging": "PATH=$HOME/.cre/bin:$PATH cre workflow simulate . --target staging-settings",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@chainlink/cre-sdk": "^1.1.1",
    "viem": "^2.21.54",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/bun": "1.3.8",
    "typescript": "^5.0.0"
  },
  "engines": {
    "bun": ">=1.2.21"
  }
}
