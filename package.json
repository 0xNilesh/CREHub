{
  "name": "crehub-root",
  "type": "module",
  "private": true,
  "workspaces": [
    "gateway",
    "backend",
    "frontend",
    "openclaw"
  ],
  "scripts": {
    "build:sdk": "cd cre-sdk-typescript/packages/cre-sdk && bun run build",
    "test:workflow": "cd cre-workflow-template && bun test",
    "test:gateway": "cd gateway && bun test",
    "test:backend": "cd backend && bun test",
    "test:contracts": "cd contracts && forge test --summary",
    "test": "bun run test:gateway && bun run test:backend",
    "dev:gateway": "cd gateway && bun run dev",
    "dev:backend": "cd backend && bun run dev",
    "dev:frontend": "cd frontend && bun run dev",
    "agent": "bun run openclaw/agent.ts",
    "agent:query": "bun run openclaw/agent.ts"
  },
  "devDependencies": {
    "@types/bun": "1.3.8"
  }
}
